OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# If free models are rate-limited, replace these with other authorized OpenRouter models.
PRIMARY_MODEL=google/gemma-3-12b-it:free
FALLBACK_MODEL=google/gemma-3-4b-it:free
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=genai_interview_trainer
WHISPER_MODEL=base
MAX_VALIDATION_RETRIES=2
REQUEST_TIMEOUT_SECONDS=45
